{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Automerge Trusted packages",
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch"],
      "matchSourceUrls": [
        "https://github.com/Captive-Studio/es-project-config"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "matchPackageNames": [
        "core-js",
        "date-fns",
        "esbuild",
        "ionicons",
        "pinia",
        "sass",
        "vue",
        "cypress",
        "vue-router",
        "tailwindcss",
        "@ionic/lab",
        "@vue/test-utils",
        "lucide-react-native",
        "react-hook-form",
        "@tanstack/react-query",
        "@uiw/react-signature",
        "libphonenumber-js",
        "lodash",
        "lucide-react-native",
        "openai",
        "qs",
        "crypto-js",
        "date-fns",
        "sweetalert2",
        "jwt-decode",
        "written-number",
        "zod",
        "jest",
        "json-stringify-pretty-compact",
        "react-syntax-highlighter",
        "react-select"
      ]
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "matchPackagePrefixes": [
        "@capacitor/",
        "@sentry/",
        "@rails/",
        "@hotwired/"
      ]
    },
    {
      "matchUpdateTypes": ["patch"],
      "matchPackageNames": ["axios"],
      "matchPackagePrefixes": ["@ionic/"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "matchManagers": ["npm"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
