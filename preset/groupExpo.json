{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
      {
      "groupName": "Expo & React Native core",
      "matchManagers": ["npm"],
      "addLabels": ["warning"],
      "prBodyNotes": [
        "ATTENTION : verifier que Expo Go est bien disponible pour la version du SDK Expo mise a jour avant de merger cette PR."
      ],
      "matchPackagePatterns": [
        "^(@expo|expo)($|[-/])",
        "^(@react|react)($|[-/])",
        "@sentry/react-native",
        "@types/react",
        "jest"
      ],
      "ignoreDeps": [
        "@react-native-community/datetimepicker",
        "@react-native-picker/picker",
        "@sentry/react-native",
        "@types/jest",
        "@types/react",
        "jest",
        "react",
        "react-dom",
        "react-native",
        "react-native-screens",
        "react-native-svg",
        "react-native-webview",
        "react-native-worklets"
      ]
    },
    {
      "description": "Ne pas mettre à jour les deps verrouillées par Expo",
      "matchPackageNames": [
        "@react-native-community/netinfo",
        "@react-navigation/bottom-tabs",
        "@react-navigation/native",
        "@shopify/flash-list",
        "react-native-safe-area-context",
        "react-native-reanimated",
        "react-native-gesture-handler"
      ],
      "enabled": false
    }
  ]
}
