{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Automerge Ruby packages",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "matchManagers": ["bundler"],
      "matchPackageNames": ["*", "!rails", "!materialize-sass"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "matchManagers": ["bundler"]
    },
    {
      "matchManagers": ["bundler"],
      "matchPackageNames": ["shoulda-matchers"],
      "automerge": true
    },
    {
      "description": "Automerge ActiveStorage en major pour 7.x → 8.x uniquement",
      "matchManagers": ["bundler"],
      "matchPackageNames": ["activestorage"],
      "matchCurrentVersion": "/^7\\./",
      "allowedVersions": ">=8.0.0 <9.0.0",
      "automerge": true
    },
    {
      "description": "Automerge solid_cable en major pour 3.x → 4.x uniquement (pas de changement cassant hors drop Ruby 3.1)",
      "matchManagers": ["bundler"],
      "matchPackageNames": ["solid_cable"],
      "matchCurrentVersion": "/^3\\./",
      "allowedVersions": ">=4.0.0 <5.0.0",
      "automerge": true
    }
  ]
}
