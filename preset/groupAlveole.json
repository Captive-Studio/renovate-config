{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Groupe les packages Alveole",
  "packageRules": [
    {
      "groupName": "[NPM] Alveole",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@alveole"]
    },
    {
      "groupName": "[NPM] Alveole automerge minor",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "matchManagers": ["npm"],
      "matchPackageNames": ["@alveole"]
    }
  ]
}
